{
  "cli": {
    "version": ">= 5.9.0"
  },
  "build": {
    "beta": {
      "env": {
        "APP_VARIANT": "beta",
        "EXPO_PUBLIC_IS_BETA": "true"
      },
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "withoutCredentials": false
      }
    },
    "beta-ios": {
      "env": {
        "APP_VARIANT": "beta",
        "EXPO_PUBLIC_IS_BETA": "true"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    },
    "production-apk": {
      "android": {
        "buildType": "apk"
      }
    },
    "preview-ios": {
      "ios": {
        "simulator": true
      }
    }
  }
}
